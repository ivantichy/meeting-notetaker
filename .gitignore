# Python
__pycache__/
*.pyc
.pytest_cache/
pytest-cache-files-*/

# Virtuální prostředí
.venv/

# Stažené modely Whisper (velké, stahují se automaticky při prvním běhu)
models/

# Lokální konfigurace — obsahuje TAJNOU ICS adresu kalendáře, necommitovat!
config.json

# Uživatelský slovník pro přepis (vzniká vedle config.json, soukromá data)
glossary.txt

# Logy
notetaker.log

# Záznamy a přepisy schůzek (soukromá data)
notes/*
!notes/.gitkeep

# Pomocný náhledový skript vzhledu (vývoj)
_theme_preview.py

# Windows installer build artefacts (PyInstaller + Inno Setup)
build/
dist/
packaging/windows/Output/
# PyInstaller spec is kept in git for reproducible builds; ignore its work dir only.
